<UserControl x:Class="SAP.Controls.EqualizerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             mc:Ignorable="d" d:DesignHeight="300" d:DesignWidth="600">
    <Border Background="#1e1e1e" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Equalizer" Foreground="#ccc" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">
                    <ToggleButton x:Name="OnOffToggle" ToolTip="Enable / Disable Equalizer"
                                  IsChecked="{Binding EqualizerEnabled}"
                                  Width="36" Height="22" VerticalAlignment="Center" Margin="0,0,4,0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                    BorderBrush="#555" BorderThickness="1">
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsChecked, Converter={x:Null}}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="10" FontWeight="Bold" Foreground="#ccc">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="ON"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="False">
                                                                    <Setter Property="Text" Value="OFF"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#1DB954"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>

                <Button Grid.Column="3" ToolTip="Save Preset" Command="{Binding SaveEqualizerPresetCommand}"
                        Width="26" Height="22" VerticalAlignment="Center" Margin="0,0,2,0"
                        Background="#444" BorderBrush="#555" BorderThickness="1" Foreground="#ccc">
                    <fa:IconBlock Icon="FloppyDisk" FontSize="12"/>
                </Button>
                <Button Grid.Column="4" ToolTip="Load Preset" Command="{Binding LoadEqualizerPresetCommand}"
                        Width="26" Height="22" VerticalAlignment="Center"
                        Background="#444" BorderBrush="#555" BorderThickness="1" Foreground="#ccc">
                    <fa:IconBlock Icon="FolderOpen" FontSize="12"/>
                </Button>
            </Grid>

            <ItemsControl x:Name="BandsContainer" Grid.Row="1" ItemsSource="{Binding EqualizerBands}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="10" Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="2,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Name}" Foreground="#aaa" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Slider Grid.Row="1" Minimum="-12" Maximum="12" Value="{Binding Gain}"
                                    Orientation="Vertical" IsDirectionReversed="True"
                                    Style="{StaticResource EqSliderStyle}"/>
                            <TextBlock Grid.Row="2" Text="{Binding GainDisplay}" Foreground="#888"
                                       FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
