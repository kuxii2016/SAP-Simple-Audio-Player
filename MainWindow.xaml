<Window x:Class="SAP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        xmlns:controls="clr-namespace:SAP.Controls"
        xmlns:local="clr-namespace:SAP"
        Title="SAP - Simple Audio Player" Height="720" Width="1100" Closing="WindowClosing"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Window.CommandBindings>
        <CommandBinding Command="MediaCommands.Play" Executed="MediaCommandExecuted"/>
        <CommandBinding Command="MediaCommands.Pause" Executed="MediaCommandExecuted"/>
        <CommandBinding Command="MediaCommands.NextTrack" Executed="MediaCommandExecuted"/>
        <CommandBinding Command="MediaCommands.PreviousTrack" Executed="MediaCommandExecuted"/>
        <CommandBinding Command="MediaCommands.Stop" Executed="MediaCommandExecuted"/>
    </Window.CommandBindings>
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToPlayPauseConverter x:Key="BoolToPlayPause"/>
        <local:Base64ImageConverter x:Key="Base64Image"/>
        <local:BoolToColorConverter x:Key="BoolToColor" ActiveColor="#1DB954" InactiveColor="#bbb"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="0" Width="4" Background="{StaticResource BgMediumBrush}"
                          HorizontalAlignment="Right" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndCurrent"/>

            <Border Grid.Column="0" Width="{Binding PlaylistWidth}"
                    Background="{StaticResource BgMediumBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BgLightBrush}" Padding="10,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Playlist" FontSize="16" FontWeight="Bold"/>
                            <Button Grid.Column="1" ToolTip="Open files" Command="{Binding OpenFileCommand}"
                                    Style="{StaticResource IconButton}" FontSize="16" Margin="2,0">
                                <fa:IconBlock Icon="FolderOpen" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Grid.Column="2" ToolTip="Open folder" Command="{Binding OpenFolderCommand}"
                                    Style="{StaticResource IconButton}" FontSize="16">
                                <fa:IconBlock Icon="FolderTree" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                        </Grid>
                    </Border>


                    <ListBox Grid.Row="2" ItemsSource="{Binding PlaylistSongs}"
                             SelectedItem="{Binding CurrentSong}"
                             Style="{StaticResource PlaylistBox}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingPanel.ScrollUnit="Pixel"
                             BorderThickness="0"
                             MouseDoubleClick="PlaylistItemDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" FontSize="13"/>
                                    <TextBlock Grid.Row="1" Text="{Binding DisplayDetails}" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" FontSize="11"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="3" Background="{StaticResource BgLightBrush}" Padding="8,6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Load" Command="{Binding LoadPlaylistCommand}" Margin="4,0" FontSize="12"/>
                            <Button Content="Save" Command="{Binding SavePlaylistCommand}" Margin="4,0" FontSize="12"/>
                            <Button Content="Clear" Command="{Binding ClearPlaylistCommand}" Margin="4,0" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BgMediumBrush}" Padding="16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="50" Height="50" Background="{StaticResource BgLightBrush}"
                                CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Image Source="{Binding CurrentSong.AlbumArt, Converter={StaticResource Base64Image}}" Stretch="UniformToFill"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding CurrentSongDisplay}" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentSong.Album}" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,0">
                                <Run Text="{Binding CurrentSong.Bitrate}"/><Run Text=" kbps"/>
                                <Run Text=" | "/>
                                <Run Text="{Binding CurrentSong.Duration, StringFormat={}{0:mm\\:ss}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="20" Background="{StaticResource BgMediumBrush}"
                            CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Viewbox Stretch="Uniform" MaxWidth="400" MaxHeight="400">
                            <Border Width="300" Height="300" Background="{StaticResource BgLightBrush}" CornerRadius="8">
                                <Image Source="{Binding CurrentSong.AlbumArt, Converter={StaticResource Base64Image}}" Stretch="UniformToFill"/>
                            </Border>
                        </Viewbox>
                    </Border>

                    <controls:EqualizerControl Grid.Row="1"
                                                Visibility="{Binding IsEqualizerVisible, Converter={StaticResource BoolToVis}}"
                                                Margin="12,0,12,12" Height="200"/>
                </Grid>

                <Border Grid.Row="2" Background="{StaticResource BgMediumBrush}" Padding="12,8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Position, StringFormat={}{0:mm\\:ss}}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="{Binding PositionMax}"
                                    Value="{Binding Position, Mode=TwoWay}"
                                    Background="{StaticResource BgLightBrush}"
                                    Foreground="{StaticResource AccentBrush}"
                                    Height="20" VerticalAlignment="Center"
                                    Style="{StaticResource {x:Type Slider}}"/>
                            <TextBlock Grid.Column="2" Text="{Binding CurrentSong.Duration, StringFormat={}{0:mm\\:ss}}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="1" ToolTip="Shuffle" Command="{Binding ToggleShuffleCommand}"
                                    Style="{StaticResource IconButton}">
                                <fa:IconBlock Icon="Shuffle"
                                              Foreground="{Binding Shuffle, Converter={StaticResource BoolToColor}}"/>
                            </Button>
                            <Button Grid.Column="2" ToolTip="Repeat" Command="{Binding ToggleRepeatCommand}"
                                    Style="{StaticResource IconButton}">
                                <fa:IconBlock Icon="Repeat"
                                              Foreground="{Binding Repeat, Converter={StaticResource BoolToColor}}"/>
                            </Button>
                            <Button Grid.Column="3" ToolTip="Previous" Command="{Binding PreviousCommand}"
                                    Style="{StaticResource IconButton}">
                                <fa:IconBlock Icon="BackwardStep" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Grid.Column="4" ToolTip="Play / Pause" Command="{Binding PlayPauseCommand}"
                                    Style="{StaticResource IconButton}" FontSize="24" Width="48" Height="48">
                                <fa:IconBlock Icon="{Binding ShowPause, Converter={StaticResource BoolToPlayPause}}"
                                              Foreground="{StaticResource AccentBrush}" FontSize="28"/>
                            </Button>
                            <Button Grid.Column="5" ToolTip="Next" Command="{Binding NextCommand}"
                                    Style="{StaticResource IconButton}">
                                <fa:IconBlock Icon="ForwardStep" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>
                            <Button Grid.Column="6" ToolTip="Stop" Command="{Binding StopCommand}"
                                    Style="{StaticResource IconButton}">
                                <fa:IconBlock Icon="Stop" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Button>

                            <Border Grid.Column="7" Margin="16,0,0,0" Background="{StaticResource BgLightBrush}"
                                    CornerRadius="4" Padding="4,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <fa:IconBlock Grid.Column="0" Icon="VolumeHigh" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Volume}"
                                            VerticalAlignment="Center" Margin="4,0"
                                            Style="{StaticResource {x:Type Slider}}"/>
                                </Grid>
                            </Border>

                            <ToggleButton Grid.Column="6" ToolTip="Toggle Equalizer"
                                          IsChecked="{Binding IsEqualizerVisible}"
                                          Background="Transparent"
                                          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                          Width="36" Height="36" Margin="8,0,0,0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4">
                                                        <fa:IconBlock Icon="Sliders" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource BgLightBrush}" Padding="12,4"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
        </Border>
    </Grid>
</Window>
